# Copy this file to `.env` (same folder as app.py) and fill in your values.
# The .env file is read at server startup by python-dotenv.
#
# How to get these:
#   1. In Telegram, message @BotFather → /newbot → follow prompts → copy the token here.
#   2. In Telegram, find your new bot and send it /start (required, otherwise the bot can't message you).
#   3. Open in your browser:  https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#      Find  "chat":{"id":<NUMBER>}  in the response — that NUMBER is your chat id.

TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-telegram-chat-id-here
